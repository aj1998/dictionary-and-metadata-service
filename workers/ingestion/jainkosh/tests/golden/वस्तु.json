        "section_kind": "siddhantkosh",
        "section_index": 0,
        "h2_text": "सिद्धांतकोष से",
        "definitions": [
          {
            "definition_index": 1,
            "blocks": [
              {
                "kind": "sanskrit_text",
                "text_devanagari": "परिणामो वस्तुलक्षणम्।",
                "hindi_translation": "परिणमन करते रहना यहाँ वस्तु का लक्षण है।",
                "references": [
                  {
                    "text": "लि.वि./मूलवृत्ति/4/15/293/11",
                    "raw_html": "<span class=\"GRef\">लि.वि./मूलवृत्ति/4/15/293/11</span>",
                    "parsed": null,
                    "inline_reference": false
                  }
                ],
                "is_orphan_translation": false,
                "is_bullet_point": false,
                "raw_html": null,
                "table_rows": null,
                "target_keyword": null,
                "target_topic_path": null,
                "target_url": null,
                "is_self": false,
                "target_exists": true
              },
              {
                "kind": "prakrit_text",
                "text_devanagari": "जं वत्थु अणेयंतं ते चिय कज्जं करेदि णियमेण। बहु धम्मजुदं अत्थं कज्जकरं दीसदे लोए।",
                "hindi_translation": "जो वस्तु अनेकांतस्वरूप है, वही नियम से कार्यकारी है। क्योंकि लोक में बहुत धर्म युक्त पदार्थ ही कार्यकारी देखा जाता है। -",
                "references": [
                  {
                    "text": "कार्तिकेयानुप्रेक्षा/225",
                    "raw_html": "<span class=\"GRef\">कार्तिकेयानुप्रेक्षा/225</span>",
                    "parsed": null,
                    "inline_reference": false
                  }
                ],
                "is_orphan_translation": false,
                "is_bullet_point": false,
                "raw_html": null,
                "table_rows": null,
                "target_keyword": null,
                "target_topic_path": null,
                "target_url": null,
                "is_self": false,
                "target_exists": true
              },
              {
                "kind": "see_also",
                "text_devanagari": null,
                "hindi_translation": null,
                "references": [],
                "is_orphan_translation": false,
