{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "JainkoshParserConfig",
  "type": "object",
  "required": ["version", "parser_rules_version", "normalization", "sections", "definitions",
               "index", "block_classes", "reference", "ref_strip", "translation_marker", "nested_span",
               "table", "redlink", "label_to_topic", "navigation", "emphasis", "headings", "slug", "bullet_strip",
               "blocks_to_drop_when_empty"],
  "additionalProperties": false,
  "properties": {
    "version": {"type": "string"},
    "parser_rules_version": {"type": "string"},
    "normalization": {
      "type": "object",
      "required": ["nfc", "strip_zwj", "strip_zwnj", "collapse_whitespace", "br_to_newline"],
      "additionalProperties": false,
      "properties": {
        "nfc": {"type": "boolean"},
        "strip_zwj": {"type": "boolean"},
        "strip_zwnj": {"type": "boolean"},
        "collapse_whitespace": {"type": "boolean"},
        "br_to_newline": {"type": "boolean"}
      }
    },
    "sections": {
      "type": "object",
      "required": ["selector", "h2_headline_selector", "kinds", "default_kind"],
      "additionalProperties": false,
      "properties": {
        "selector": {"type": "string"},
        "h2_headline_selector": {"type": "string"},
        "kinds": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "kind"],
            "additionalProperties": false,
            "properties": {
              "id": {"type": "string"},
              "kind": {"type": "string"}
            }
          }
        },
        "default_kind": {"type": "string"}
      }
    },
    "definitions": {
      "type": "object",
      "required": ["siddhantkosh", "puraankosh"],
      "additionalProperties": false,
      "properties": {
        "siddhantkosh": {
          "type": "object",
          "required": ["boundary"],
          "additionalProperties": false,
          "properties": {"boundary": {"type": "string"}}
        },
        "puraankosh": {
          "type": "object",
          "required": ["boundary"],
          "additionalProperties": false,
          "properties": {"boundary": {"type": "string"}}
        }
      }
    },
    "index": {
      "type": "object",
      "required": ["enabled_for", "outer_list_selector", "inner_anchor_ignore_selector",
                   "see_also_list_selector", "self_link_class"],
      "additionalProperties": false,
      "properties": {
        "enabled_for": {"type": "array", "items": {"type": "string"}},
        "outer_list_selector": {"type": "string"},
        "inner_anchor_ignore_selector": {"type": "string"},
        "see_also_list_selector": {"type": "string"},
        "self_link_class": {"type": "string"},
        "see_also_triggers": {
          "type": "array",
          "items": {"type": "string"},
          "minItems": 1
        },
        "see_also_window_chars": {"type": "integer", "minimum": 1, "maximum": 200},
        "see_also_leading_punct_re": {"type": "string"},
        "see_also_text_pattern": {"type": "string", "deprecated": true}
      }
    },
    "block_classes": {
      "type": "object",
      "additionalProperties": {"type": "string"}
    },
    "reference": {
      "type": "object",
      "required": ["selector", "strip_inner_anchors"],
      "additionalProperties": false,
      "properties": {
        "selector": {"type": "string"},
        "strip_inner_anchors": {"type": "boolean"},
        "parse_strategy": {
          "type": "string",
          "enum": ["text_only", "structured", "text_plus_structured"]
        }
      }
    },
    "ref_strip": {
      "type": "object",
      "required": ["enabled", "collapse_double_spaces", "collapse_orphan_parens", "collapse_orphan_brackets", "trim_trailing_chars"],
      "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean"},
        "collapse_double_spaces": {"type": "boolean"},
        "collapse_orphan_parens": {"type": "boolean"},
        "collapse_orphan_brackets": {"type": "boolean"},
        "trim_trailing_chars": {"type": "string"}
      }
    },
    "translation_marker": {
      "type": "object",
      "required": ["prefix", "source_kinds", "hindi_kinds"],
      "additionalProperties": false,
      "properties": {
        "prefix": {"type": "string"},
        "source_kinds": {"type": "array", "items": {"type": "string"}},
        "hindi_kinds": {"type": "array", "items": {"type": "string"}},
        "sibling_marker_enabled": {"type": "boolean"},
        "sibling_marker_text_node_re": {"type": "string"},
        "reference_ordering": {"type": "string", "enum": ["leading_then_inline", "document_order"]}
      }
    },
    "nested_span": {
      "type": "object",
      "required": ["flatten", "outer_kinds"],
      "additionalProperties": false,
      "properties": {
        "flatten": {"type": "boolean"},
        "outer_kinds": {"type": "array", "items": {"type": "string"}}
      }
    },
    "table": {
      "type": "object",
      "required": ["selector", "store_raw_html", "attach_to"],
      "additionalProperties": false,
      "properties": {
        "selector": {"type": "string"},
        "store_raw_html": {"type": "boolean"},
        "extraction_strategy": {
          "type": "string",
          "enum": ["raw_html_only", "raw_html_plus_rows"]
        },
        "attach_to": {"type": "string", "enum": ["current_subsection", "section_root"]},
        "fallback_when_no_subsection": {"type": "string", "enum": ["section_root"]}
      }
    },
    "redlink": {
      "type": "object",
      "required": ["enabled", "anchor_class", "title_marker_re", "href_marker_substring", "prose_strip"],
      "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean"},
        "anchor_class": {"type": "string"},
        "title_marker_re": {"type": "string"},
        "href_marker_substring": {"type": "string"},
        "prose_strip": {
          "type": "object",
          "required": ["enabled", "connector_re"],
          "additionalProperties": false,
          "properties": {
            "enabled": {"type": "boolean"},
            "connector_re": {"type": "string"}
          }
        }
      }
    },
    "label_to_topic": {
      "type": "object",
      "required": ["enabled", "emit_for_redlink", "emit_for_wiki_link", "emit_for_self_link",
                   "bullet_prefixes", "label_trim_chars", "attach_to", "is_synthetic", "is_leaf", "source_marker"],
      "additionalProperties": false,
      "properties": {
        "enabled": {"type": "boolean"},
        "emit_for_redlink": {"type": "boolean"},
        "emit_for_wiki_link": {"type": "boolean"},
        "emit_for_self_link": {"type": "boolean"},
        "bullet_prefixes": {"type": "array", "items": {"type": "string"}},
        "label_trim_chars": {"type": "string"},
        "attach_to": {"type": "string", "enum": ["current_subsection", "section_root"]},
        "is_synthetic": {"type": "boolean"},
        "is_leaf": {"type": "boolean"},
        "source_marker": {"type": "string"}
      }
    },
    "navigation": {
      "type": "object",
      "required": ["drop", "prev_text", "next_text", "containing_tag"],
      "additionalProperties": false,
      "properties": {
        "drop": {"type": "boolean"},
        "prev_text": {"type": "string"},
        "next_text": {"type": "string"},
        "containing_tag": {"type": "string"}
      }
    },
    "emphasis": {
      "type": "object",
      "required": ["bold_to_markdown", "italic_to_markdown"],
      "additionalProperties": false,
      "properties": {
        "bold_to_markdown": {"type": "boolean"},
        "italic_to_markdown": {"type": "boolean"}
      }
    },
    "headings": {
      "type": "object",
      "required": ["variants"],
      "additionalProperties": false,
      "properties": {
        "variants": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["name", "selector", "id_from", "heading_text"],
            "additionalProperties": false,
            "properties": {
              "name": {"type": "string"},
              "selector": {"type": "string"},
              "id_from": {"type": "string"},
              "heading_text": {"type": "string"},
              "regex": {"type": "string"}
            }
          }
        }
      }
    },
    "slug": {
      "type": "object",
      "required": ["preserve_devanagari", "strip_chars", "whitespace_to",
                   "collapse_dashes", "strip_v4_numeric_prefix"],
      "additionalProperties": false,
      "properties": {
        "preserve_devanagari": {"type": "boolean"},
        "strip_chars": {"type": "string"},
        "whitespace_to": {"type": "string"},
        "collapse_dashes": {"type": "boolean"},
        "strip_v4_numeric_prefix": {"type": "boolean"}
      }
    },
    "bullet_strip": {
      "type": "object",
      "required": ["prefixes", "trailing_punct"],
      "additionalProperties": false,
      "properties": {
        "prefixes": {"type": "array", "items": {"type": "string"}},
        "trailing_punct": {"type": "array", "items": {"type": "string"}}
      }
    },
    "blocks_to_drop_when_empty": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
